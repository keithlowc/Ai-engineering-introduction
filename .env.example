# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,keithlowdev.com

# Database Configuration
DATABASE_URL=postgresql://postgres:password@db:5432/keithlowdev
POSTGRES_DB=keithlowdev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-here

# AWS Configuration (if using S3 for media/static files)
AWS_ACCESS_KEY_ID=your-aws-access-key-here
AWS_SECRET_ACCESS_KEY=your-aws-secret-key-here
AWS_STORAGE_BUCKET_NAME=keithlowdev-bucket

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here
EMAIL_USE_TLS=True
