# Django Settings
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=property_crm_db
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
